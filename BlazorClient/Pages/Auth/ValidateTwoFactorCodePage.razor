@page "/auth/validate-two-factor-code/{UserId}"

<EditForm Model="@model" OnValidSubmit="HandleValidSubmitAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="form-group">
        <label for="twoFactorCode">Two factor code</label>
        <InputText id="twoFactorCode" class="form-control" @bind-Value="model.TwoFactorCode" />
        <ValidationMessage For="@(() => model.TwoFactorCode)" />
    </div>

    <div class="form-group">
        <button type="submit" class="btn btn-primary">Validate two factor code</button>
    </div>
</EditForm>
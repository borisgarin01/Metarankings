@page "/auth/login"

<div class="login-container">
    @if (!IsTwoFactorRequired)
    {
        <h3>Вход в систему</h3>

        <div class="form-group">
            <label>Email</label>
            <input type="email" class="form-control"
                   @bind="LoginModel.UserEmail"
                   @bind:event="oninput" />
        </div>

        <div class="form-group">
            <label>Пароль</label>
            <input type="password" class="form-control"
                   @bind="LoginModel.Password"
                   @bind:event="oninput" />
        </div>

        <button class="btn btn-primary" @onclick="LoginAsync" disabled="@IsLoading">
            @if (IsLoading)
            {
                <span class="spinner-border spinner-border-sm"></span>
            }
            Войти
        </button>
    }
    else
    {
        <h3>Двухфакторная аутентификация</h3>
        <p>Введите код подтверждения, отправленный на вашу почту</p>

        <div class="form-group">
            <label>Код подтверждения</label>
            <input type="text" class="form-control"
                   @bind="TwoFactorCode"
                   @bind:event="oninput"
                   maxlength="6"
                   placeholder="6-значный код" />
        </div>

        <div class="button-group">
            <button class="btn btn-primary" @onclick="LoginAsync" disabled="@IsLoading">
                @if (IsLoading)
                {
                    <span class="spinner-border spinner-border-sm"></span>
                }
                Подтвердить
            </button>

            <button class="btn btn-secondary" @onclick="CancelTwoFactor" disabled="@IsLoading">
                Назад
            </button>
        </div>

        <div class="mt-3">
            <button class="btn btn-link" @onclick="ResendTwoFactorCode">
                Отправить код повторно
            </button>
        </div>
    }
</div>
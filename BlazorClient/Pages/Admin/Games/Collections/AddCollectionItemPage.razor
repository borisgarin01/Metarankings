@page "/admin/games/collections/{Id:long}/add-games"
@using Domain.Games
<h3>AddCollectionItemPage</h3>

<AuthorizeView Policy="Admin">
    <Authorized>
        <EditForm OnValidSubmit="@AddGameCollectionItemAsync" Model="this" Context="myContext">
            <div>
                <select @onchange="SelectGame">
                    <option value="-1" selected>None</option>
                    @foreach (Game game in GamesToSelectFrom)
                    {
                        <option value="@game.Id.ToString()">@game.Name</option>
                    }
                </select>
                <input type="submit" value="Add" />
            </div>
        </EditForm>
    </Authorized>
    <NotAuthorized>
        <a href="/auth/login">Авторизируйся</a> или <a href="/auth/register">Зарегистрируйся</a> админом, чтобы добавить игру в подборку
    </NotAuthorized>
</AuthorizeView>
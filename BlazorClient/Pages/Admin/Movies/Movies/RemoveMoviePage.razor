@page "/admin/movies/remove-movie/{Id:long}"


<AuthorizeView Policy="Admin">
    <Authorized>
        <a href="/admin">К странице админа</a>
        @if (Movie is null)
        {
            <p>Загружается...</p>
        }
        else
        {
            <a href="/admin/movies/movies/list-/movies" class="list-group-item link-dark">Фильмы</a>

            <h3>Удалить @Movie.Name</h3>
            <p>Вы уверены, что хотите удалить этот фильм?</p>
            <p>
                <button type="button" @onclick="RemoveMovieAsync">Удалить</button>
            </p>
        }
    </Authorized>
    <NotAuthorized>
        <a href="/auth/login">Авторизируйся</a> или <a href="/auth/register">Зарегистрируйся</a> админом, чтобы удалить фильм
    </NotAuthorized>
</AuthorizeView>

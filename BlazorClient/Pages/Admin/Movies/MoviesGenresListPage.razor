@page "/admin/movies/movies-genres/movies-genres-list"

@using Domain.Games
@using Domain.Movies

<AuthorizeView Policy="Admin">
    <Authorized>
        <a href="/admin/movies/movies-genres/add-movie-genre">Добавить жанр</a>
        <div class="genresList">
            @if (MoviesGenres is null)
            {
                <p>Загружается...</p>
            }
            else
            {
                foreach (MovieGenre movieGenre in MoviesGenres)
                {
                    <div class="genre">
                        <h4>@movieGenre.Name</h4>
                        <a href="/admin/movies/movies-genres/remove-movie-genre/@movieGenre.Id">Remove genre</a>
                    </div>
                }
            }
        </div>
    </Authorized>
    <NotAuthorized>
        <a href="/auth/login">Авторизируйся</a> или <a href="/auth/register">Зарегистрируйся</a>, чтобы добавить жанр фильма
    </NotAuthorized>
</AuthorizeView>

@page "/admin/movies/movies-directors/remove-movie-director/{Id:long}"

<AuthorizeView Policy="Admin">
    <Authorized>
        <a href="/admin">К странице админа</a>
        @if (MovieDirector is null)
        {
            <p>Загружается...</p>
        }
        else
        {
            <h3>Удалить @MovieDirector.Name</h3>
            <p>Вы уверены, что хотите удалить этого режиссера?</p>
            <p>
                <button type="button" @onclick="RemoveMovieDirectorAsync">Удалить</button>
            </p>
        }
    </Authorized>
    <NotAuthorized>
        <a href="/auth/login">Авторизируйся</a> или <a href="/auth/register">Зарегистрируйся</a> админом, чтобы удалить платформу
    </NotAuthorized>
</AuthorizeView>
@page "/admin/movies/movies-studios/remove-movie-studio/{Id:long}"

<AuthorizeView Policy="Admin">
    <Authorized>
        <a href="/admin">К странице админа</a>
        @if (MovieStudio is null)
        {
            <p>Загружается...</p>
        }
        else
        {
            <h3>Удалить @MovieStudio.Name</h3>
            <p>Вы уверены, что хотите удалить эту киностудию?</p>
            <p>
                <button type="button" @onclick="RemoveMovieStudioAsync">Удалить</button>
            </p>
        }
    </Authorized>
    <NotAuthorized>
        <a href="/auth/login">Авторизируйся</a> или <a href="/auth/register">Зарегистрируйся</a> админом, чтобы удалить платформу
    </NotAuthorized>
</AuthorizeView>

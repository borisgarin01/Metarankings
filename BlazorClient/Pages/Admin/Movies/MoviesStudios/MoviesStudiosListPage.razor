@page "/admin/movies/movies-studios/movies-studios-list"
@using Domain.Movies

<AuthorizeView Policy="Admin">
    <Authorized>
        <a href="/admin">К странице админа</a>
        <a href="/admin/movies/movies-studios/add-movie-studio">Добавить студию</a>
        <div class="genresList">
            @if (MoviesStudios is null)
            {
                <p>Загружается...</p>
            }
            else
            {
                foreach (MovieStudio movieStudio in MoviesStudios)
                {
                    <div class="movieStudio">
                        <h4>@movieStudio.Name</h4>
                        <a href="/admin/movies/movies-studios/remove-movie-studio/@movieStudio.Id">Удалить студию</a>
                    </div>
                }
            }
        </div>
    </Authorized>
    <NotAuthorized>
        <a href="/auth/login">Авторизируйся</a> или <a href="/auth/register">Зарегистрируйся</a>, чтобы добавить киностудию
    </NotAuthorized>
</AuthorizeView>

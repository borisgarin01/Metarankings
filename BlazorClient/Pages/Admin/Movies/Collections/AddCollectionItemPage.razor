@page "/admin/movies/collections/{Id:long}/add-movie"
@using Domain.Movies

<h3>AddCollectionItemPage</h3>

<AuthorizeView Policy="Admin">
    <Authorized>
        <EditForm OnValidSubmit="@AddMovieCollectionItemAsync" Model="this" Context="myContext">
            <div>
                <select @onchange="SelectMovie">
                    <option value="-1" selected>None</option>
                    @foreach (Movie movie in MoviesToSelectFrom)
                    {
                        <option value="@movie.Id.ToString()">@movie.Name</option>
                    }
                </select>
                <input type="submit" value="Add" />
            </div>
        </EditForm>
    </Authorized>
    <NotAuthorized>
        <a href="/auth/login">Авторизируйся</a> или <a href="/auth/register">Зарегистрируйся</a> админом, чтобы добавить подборку
    </NotAuthorized>
</AuthorizeView>
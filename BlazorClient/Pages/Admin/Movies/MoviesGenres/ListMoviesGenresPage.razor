@page "/admin/movies/movies-genres/list-genres"
@using Domain.Games
@using Domain.Movies

<AuthorizeView Policy="Admin">
    <Authorized>
        <a href="/admin">К странице админа</a>
        <a href="/admin/movies/movies-genres/add-movie-genre">Добавить жанр</a>
        <div class="gamesList">
            @if (Genres is null)
            {
                <p>Загружается...</p>
            }
            else
            {
                foreach (Genre genre in Genres)
                {
                    <div class="movie">
                        <h4>@genre.Name</h4>
                        <a href="/admin/genres/remove-genre/@genre.Id">Remove movie</a>
                        <a href="/movies/Details/@genre.Id">Details</a>
                    </div>
                }
            }
        </div>
    </Authorized>
    <NotAuthorized>
        <a href="/auth/login">Авторизируйся</a> или <a href="/auth/register">Зарегистрируйся</a>, чтобы добавить игру
    </NotAuthorized>
</AuthorizeView>

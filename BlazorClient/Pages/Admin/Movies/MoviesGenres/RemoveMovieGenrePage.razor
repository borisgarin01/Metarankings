@page "/admin/movies/movies-genres/remove-movie-genre/{Id:long}"

<AuthorizeView Policy="Admin">
    <Authorized>
        @if (MovieGenre is null)
        {
            <p>Загружается...</p>
        }
        else
        {
            <h3>Удалить @MovieGenre.Name</h3>
            <p>Вы уверены, что хотите удалить этот жанр фильмов?</p>
            <p>
                <button type="button" @onclick="RemoveMovieGenreAsync">Удалить</button>
            </p>
        }
    </Authorized>
    <NotAuthorized>
        <a href="/auth/login">Авторизируйся</a> или <a href="/auth/register">Зарегистрируйся</a> админом, чтобы удалить платформу
    </NotAuthorized>
</AuthorizeView>

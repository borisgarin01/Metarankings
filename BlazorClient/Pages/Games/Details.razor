@page "/games/details/{Name}"
﻿@using Domain;
@inject HttpClient HttpClient;
@inject NavigationManager NavigationManager;


@if (Game is null)
{
    <div class="mynavbar">Loading...</div>
}
else
{
    <div class="post single clear game" id="post_13091">
        <div class="post-meta">
            <h1><span itemprop="name">@Game.Name</span></h1>
            <meta itemprop="headline" content="@Game.Name">
            <meta itemprop="description" content=@Game.Description>
            <link itemprop="url" href="@NavigationManager.Uri">
            <meta itemprop="dateCreated" content="2020">
        </div>
        <div class="post-content">
            <div class="thumb">
                <img class="post-image" src="@Game.ImageSource" alt="Игра @Game.Name" title="Игра @Game.Name" itemprop="image">
                <div class="best-prod">
                    <span class="star">★</span> Лучшие в @Game.ReleaseDate.Year году <span class="inform">?</span>
                </div>
                <div class="watch-trailer">
                    <h3><span class="twatch"><span class="p-twatch">Смотреть трейлер</span></span></h3>
                </div>
            </div>
            <div id="ratings">

                <div class="ratings mark-@Math.Round(Game.Score.Value)">
                    <div id="post-ratings-13091" class="post-ratings" data-nonce="8b2eb167f0">
                        <div class="rating">
                            <div class="score">
                                @Game.Score
                            </div>
                            Оценки: <span>439</span>
                        </div>
                        <div class="your-score">
                            <img id="rating_13091_1" class="rating-on mark-1" src="https://metarankings.ru/wp-content/plugins/wp-postratings/images/squares/rating_on.gif" alt="1" style="cursor: pointer;"> <span class="post-ratings-text" id="ratings_13091_text">0</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="featured-game">
                <p>
                    <span class="label">Разработчик:</span>
                    @foreach (var developer in Game.Developers)
                    {
                        <a itemprop="author" href="@developer.Url"> @developer.Name</a>
                    }
                </p>
                <p>
                    <span class="label">Издатель:</span>
                    @foreach (var publisher in Game.Publishers)
                    {
                        <a itemprop="publisher" href="@publisher.Url">@publisher.Name</a>
                    }
                </p>
                <p>
                    <span class="label">Платформы:</span>
                    <span itemprop="gamePlatform">
                        @foreach (var platform in Game.Platforms)
                        {
                            <a href="@platform.Url">@platform.Name</a>
                        }
                    </span>
                </p>
                <p>
                    <span class="label">Жанр:</span>
                    <span itemprop="genre">
                        @foreach (var genre in Game.Genres)
                        {
                            <a href="@genre.Url">@genre.Name</a>
                            <text>, </text>
                        }
                    </span>
                </p>
                <p><span class="label">Локализация:</span> <span itemprop="inLanguage"><a href="@Game.Localization.Url">@Game.Localization.Title</a></span></p>
                <p><span class="label">Дата выхода:</span> <span>@Game.ReleaseDate.ToString("dd MMMM yyyy")</span></p>
            </div>

            <div class="description">
                <h3>Описание</h3>
                <div>
                    <p>@Game.Description</p>
                </div>

            </div>
            <div class="systems">
                <h2 onclick="jQuery( document ).ready(function($){$('.system-info').slideToggle('fast')});">Системные требования</h2>
                <div class="system-info">
                    Минимальные требования:
                    <table class="systems">
                        <tbody>
                            <tr>
                                <td><strong>Операционная система:</strong></td>
                                <td itemprop="operatingSystem">PS5</td>
                            </tr>
                            <tr>
                                <td><strong>Процессор:</strong></td>
                                <td itemprop="processorRequirements">—</td>
                            </tr>
                            <tr>
                                <td><strong>Оперативная память:</strong></td>
                                <td itemprop="memoryRequirements">—</td>
                            </tr>
                            <tr>
                                <td><strong>Видеокарта:</strong></td>
                                <td>—</td>
                            </tr>
                            <tr>
                                <td><strong>Место на диске:</strong></td>
                                <td itemprop="storageRequirements">—</td>
                            </tr>
                        </tbody>
                    </table>
                    Рекомендуемые требования:
                    <table class="systems">
                        <tbody>
                            <tr>
                                <td><strong>Операционная система:</strong></td>
                                <td>PS5</td>
                            </tr>
                            <tr>
                                <td><strong>Процессор:</strong></td>
                                <td>—</td>
                            </tr>
                            <tr>
                                <td><strong>Оперативная память:</strong></td>
                                <td>—</td>
                            </tr>
                            <tr>
                                <td><strong>Видеокарта:</strong></td>
                                <td>—</td>
                            </tr>
                            <tr>
                                <td><strong>Место на диске:</strong></td>
                                <td>—</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="podborki">
                <p>
                    <a href="https://metarankings.ru/best-games-@Game.ReleaseDate.Year/">Игры @Game.ReleaseDate.Year</a>
                    @if (Game.Platforms.Any())
                    {
                        <a class="mark-link" href=@Game.Platforms.First().Url>Топ игр на @Game.Platforms.First().Name</a>
                    }
                    @if (Game.Genres.Any())
                    {
                        <a class="mark-link" href=@Game.Genres.First().Url>ролевые игры</a>
                    }
                    <a class="mark-link" href="https://metarankings.ru/samye-krasivye-igry-dlya-pc-i-konsolej/">красивые игры</a>
                </p>
            </div>
        </div>
        <div class="ads-horizont hor-1">
            <!-- Yandex.RTB R-A-201169-7 -->
            <div id="yandex_rtb_R-A-201169-7-1" data-3ecefee879=""><div style="width: 100%;"></div><div data-r-a-201169-7-yandex_rtb_r-a-201169-7-1="" style="position: absolute; display: none; visibility: hidden; width: 0px; height: 0px;"></div></div>
            <script>
                window.yaContextCb.push(()=>{
                Ya.Context.AdvManager.render({
                renderTo: 'yandex_rtb_R-A-201169-7-1',
                blockId: 'R-A-201169-7'
                })
                })</script>
        </div>
        <div class="post-footer">
            <h3>Трейлер и скриншоты</h3>
            <div id="tcontent">
                <div class="video-content" itemprop="subjectOf" itemscope="" itemtype="https://schema.org/VideoObject">
                    <div id="content-trailer">
                        <meta itemprop="isFamilyFriendly" content="true">
                        <meta itemprop="uploadDate" content="2020-11-12T00:55:08+00:00">
                        <link itemprop="url" href="@NavigationManager.Uri">
                        <meta itemprop="name" content="Трейлер @Game.Name">
                        <meta itemprop="description" content="Трейлер игры @Game.Name">
                        <link itemprop="thumbnail" href="@Game.ImageSource">
                        <link itemprop="thumbnailUrl" href="@Game.ImageSource">
                        @foreach (var videoUrl in Game.Trailers)
                        {
                            <link itemprop="embedUrl" href="@videoUrl.Url">
                        }
                        @foreach (var videoUrl in Game.Trailers)
                        {
                            <iframe title="Трейлер @Game.Name" src="@videoUrl.Url" height="240" width="670" allowfullscreen="" style="border-width:0"></iframe>
                        }
                    </div>
                </div>
            </div>
            <ul class="gallery">
                <li><img class="attachment-screenshot" src="@Game.ImageSource" data-original="@Game.ImageSource" alt="Скриншоты @Game.Name" title="@Game.Name" width="100" height="75"></li>
                <li><img class="attachment-screenshot" src="@Game.ImageSource" data-original="@Game.ImageSource" alt="Скриншоты @Game.Name" title="@Game.Name" width="100" height="75"></li>
                <li><img class="attachment-screenshot" src="@Game.ImageSource" data-original="@Game.ImageSource" alt="Скриншоты @Game.Name" title="@Game.Name" width="100" height="75"></li>
                <li><img class="attachment-screenshot" src="@Game.ImageSource" data-original="@Game.ImageSource" alt="Скриншоты @Game.Name" title="@Game.Name" width="100" height="75"></li>
                <li><img class="attachment-screenshot" src="@Game.ImageSource" data-original="@Game.ImageSource" alt="Скриншоты @Game.Name" title="@Game.Name" width="100" height="75"></li>
            </ul>
        </div>
    </div>
}

@code {
    [Parameter]
    public string Name { get; set; }

    public Game Game { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Game = await HttpClient.GetFromJsonAsync<Game>($"api/GamesDetailsPage/{Name}");
    }
}
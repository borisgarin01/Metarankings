@using Domain.ViewModels
@inject HttpClient HttpClient

@page "/add-game"

<div class="form-control">
    <input type="text" @bind-value="@Name" />
    <input type="number" @bind-value="@Score" />
    <input type="text" @bind-value="@Image" />
    <input type="text" @bind-value="@Description" />
    <input type="tel" @bind-value="@LocalizationId" />
    <input type="date" @bind-value="@ReleaseDate" />
    <input type="submit" @onclick="@AddGameAsync" />
</div>

@code {
    public string Name { get; set; }
    public float? Score { get; set; }
    public string Image { get; set; }
    public string Description { get; set; }
    public long? LocalizationId { get; set; }
    public DateTime? ReleaseDate { get; set; }

    public async Task AddGameAsync()
    {
        var addGameViewModel = new AddGameViewModel
            {
                Description = Description,
                ImageSource = Image,
                LocalizationId = LocalizationId,
                Name = Name,
                ReleaseDate = ReleaseDate,
                Score = Score
            };

        await HttpClient.PostAsJsonAsync<AddGameViewModel>("api/GamesAdmin", addGameViewModel);
    }
}
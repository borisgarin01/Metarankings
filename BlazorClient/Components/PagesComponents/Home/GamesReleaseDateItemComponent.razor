@using Domain.Common
<div class="item">
    <a href="@Href" title="@Title"><img class="post-image" src="@ImageSource" alt="@ImageAlt"></a>
    <span class="item-name"><a href="@Href">@ItemName</a></span>
    <span class="item-meta">
        @foreach (Link platform in Platforms)
        {
            <a href="@platform.Url">@platform.Title</a>
        }
    </span>
    <span class="item-meta">
        @foreach (Link genre in Genres)
        {
            <a href="@genre.Url">@genre.Title</a>
        }
    </span>
    <span class="item-meta">@ReleaseDate.ToString("dd MMMM yyyy")</span>
</div>
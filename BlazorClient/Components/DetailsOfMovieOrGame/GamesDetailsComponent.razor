@code {
    public DetailsComponentItem DetailsComponentItem { get; set; }

    [Parameter]
    public string Title { get; set; }

    protected override async Task OnInitializedAsync()
    {
        DetailsComponentItem = await HttpClient.GetFromJsonAsync<DetailsComponentItem>($"api/GamesDetailsPage/{Title}");
    }
}

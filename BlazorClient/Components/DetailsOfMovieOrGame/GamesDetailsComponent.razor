@page "/games/details/{Name}"
@using Domain
@using System.Globalization

@inject HttpClient HttpClient

<Headerer />

<div class="wrapper">
    <GameMenu />
    <div id="container" class="clear">
        <div class="sidebar">
        </div>
        <div id="content" class="lcol">
            <div class="entry" itemscope itemtype="http://schema.org/VideoGame">
                <div class="post single clear game" id="post_25216">

                    <div class="featured-game">
                        <p>
                            <span class="label">Разработчик:</span> @foreach (var developer in FeaturedGame.Developers)
                            {
                                <NavLink class="my-nav-link" href="/games/details/alex">@developer.Name</NavLink>

                                <text>, </text>
                            }
                        </p>
                        <p>
                            <span class="label">Издатель:</span> @foreach (var publisher in FeaturedGame.Publishers)
                            {
                                <NavLink class="my-nav-link" href="/games/details/alex">@publisher.Name</NavLink>

                                <text>, </text>
                            }
                        </p>
                        <p>
                            <span class="label">Платформы:</span> <span itemprop="gamePlatform">
                                @foreach (var platform in FeaturedGame.Platforms)
                                {
                                    <NavLink class="my-nav-link" href="/games/details/alex">@platform.Name</NavLink>
                                    <text>, </text>
                                }
                            </span>
                        </p>
                        <p>
                            <span class="label">Жанр:</span> <span itemprop="genre">
                                @foreach (var genre in FeaturedGame.Genres)
                                {
                                    <NavLink class="my-nav-link" href="/games/details/alex">@genre.Name</NavLink>
                                }
                            </span>
                        </p>
                        <p><span class="label">Локализация:</span> <span itemprop="inLanguage"></span> (<NavLink class="my-nav-link" href="/games/details/alex">@FeaturedGame.Localization.Name</NavLink>)</p>
                        @if (FeaturedGame.ReleaseDate != default(DateTime))
                        {
                            <p><span class="label">Дата выхода:</span> @FeaturedGame.ReleaseDate.ToString("dd MM yyyy", new CultureInfo("RU-ru"))</p>
                        }
                    </div>

                    <div class="description">
                        <h3>Описание</h3>

                    </div>

                    <div class="podborki">
                        <p>
                            <NavLink class="my-nav-link" href="/games/details/alex">Игры 2024</NavLink>
                            <NavLink class="mark-link" href="/games/details/alex">Топ игр на ПК</NavLink>
                            <NavLink class="mark-link" href="/games/details/alex">хорроры</NavLink>
                        </p>
                    </div>
                </div>

                                <iframe title="Трейлер The Thing: Remastered" height="240" width="670" src="https://rutube.ru/play/embed/fabe696a815d1dd20645285e0eb9016c" frameBorder="0" allow="clipboard-write; autoplay" webkitAllowFullScreen mozallowfullscreen allowFullScreen></iframe>

<div class="news-item">
    <a href="@Href" title="@Title"><img class="news-thumb" src="@ImageSrc" alt="Самые сложные игры"></a>
    <span class="news-title"><a href="@Href">Самые сложные игры</a></span>
    <div class="rubrika"><a href="https://metarankings.ru/meta/collections/films-games/">Контент</a></div>
</div>

@code {
    [Parameter]
    public string Href { get; set; }

    [Parameter]
    public string Title { get; set; }

    [Parameter]
    public string ImageSrc { get; set; }
}
